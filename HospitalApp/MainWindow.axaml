<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:HospitalApp.PresentationLayer.ViewModels"
        xmlns:domain="clr-namespace:HospitalApp.Domain.Entities"
        x:Class="HospitalApp.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Больница" Width="800" Height="500">

    <StackPanel Margin="12" Spacing="10">
        <TextBlock Text="Больница — список пациентов" FontSize="20" />

        <Button Content="Принять тестового пациента" Click="OnAdmitClick" Width="250"/>

        <ListBox ItemsSource="{Binding Patients}"
                 SelectedItem="{Binding SelectedPatient, Mode=TwoWay}"
                 Height="200">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="domain:Patient">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="{Binding FirstName}" />
                        <TextBlock Text="{Binding LastName}" />
                        <TextBlock Text="{Binding DateOfBirth, StringFormat=' (д.р. {0:dd.MM.yyyy})'}" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="Открыть ЭМК" Click="OnOpenEmkClick" IsEnabled="{Binding SelectedPatient}" />
            <Button Content="Выписать" Click="OnDischargeClick" IsEnabled="{Binding SelectedPatient}" />
        </StackPanel>

        <TextBlock Text="{Binding InfoMessage}" FontStyle="Italic" />
    </StackPanel>
</Window>